{
  "name": "opendoor-mcp-server",
  "version": "2.0.0",
  "description": "Production-grade MCP server with multi-language code execution, VS Code integration, and browser automation",
  "main": "mcp-server/dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "cd mcp-server && npm start",
    "dev": "cd mcp-server && npm run dev", 
    "build": "cd mcp-server && npm run build",
    "test": "cd mcp-server && npm test",
    "lint": "cd mcp-server && npm run lint",
    "lint:fix": "cd mcp-server && npm run lint:fix",
    "health": "curl -f http://localhost:50063/health || exit 1",
    "clean": "cd mcp-server && npm run clean",
    "setup": "cd mcp-server && npm install && npm run build",
    "install:mcp": "cd mcp-server && npm install"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "large-language-models",
    "code-execution",
    "vscode",
    "playwright",
    "virtual-environments",
    "isolation",
    "browser-automation",
    "production-grade",
    "high-performance",
    "security",
    "enterprise",
    "multi-language",
    "python",
    "javascript",
    "typescript",
    "java",
    "rust",
    "go"
  ],
  "author": "Opendoor Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/make-change-code/Opendoor.git"
  },
  "bugs": {
    "url": "https://github.com/make-change-code/Opendoor/issues"
  },
  "homepage": "https://github.com/make-change-code/Opendoor#readme"
}
